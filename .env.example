# ============================================================
# ToolTime Pro — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for OAuth callbacks, email links, redirects)
NEXT_PUBLIC_APP_URL=https://app.tooltimepro.com

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICES={"starter":{"monthly":"price_...","annual":"price_..."},...}

# AI — Claude is primary, OpenAI is fallback
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Email (Resend)
RESEND_API_KEY=re_...

# Twilio (SMS + 2FA)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
TWILIO_MESSAGING_SERVICE_SID=MG...  # A2P 10DLC campaign — preferred over raw phone number
TWILIO_2FA_MESSAGING_SERVICE_SID=MG...

# QuickBooks (optional — only if QB integration enabled)
QUICKBOOKS_CLIENT_ID=...
QUICKBOOKS_CLIENT_SECRET=...
QUICKBOOKS_REDIRECT_URI=https://your-site.com/api/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Google Calendar (optional — only if GCal integration enabled)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Name.com Domain Registration (optional — only for website builder)
NAMECOM_USERNAME=...
NAMECOM_API_TOKEN=...
NAMECOM_TEST_USERNAME=...
NAMECOM_TEST_TOKEN=...

# Cron Security (required — protects scheduled functions)
CRON_SECRET=your-random-secret-here

# Platform Admin
PLATFORM_ADMIN_EMAILS=admin@yourcompany.com
